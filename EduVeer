// ═══════════════════════════════════════════════
function openExam(examId) {
  currentExamId = examId;
  const exam = EXAMS.find(e => e.id === examId);
  document.getElementById('breadExam').textContent = exam.name;
  document.getElementById('examPageTitle').textContent = exam.name + ' Mock Tests';
  document.getElementById('examPageSub').textContent = exam.desc;

  const qs = QUESTION_BANK[examId] || defaultQuestions;
  const tests = [
    {title:`${exam.name} Full Test 1`, qs:qs.length, mins:60, diff:'medium', attempts:'12,450'},
    {title:`${exam.name} Chapter Test`, qs:Math.min(5,qs.length), mins:15, diff:'easy', attempts:'8,230'},
    {title:`${exam.name} Previous Year 2024`, qs:qs.length, mins:60, diff:'hard', attempts:'24,100'},
    {title:`${exam.name} Quick Revision`, qs:Math.min(5,qs.length), mins:10, diff:'easy', attempts:'5,600'},
    {title:`${exam.name} Mock Test 2`, qs:qs.length, mins:60, diff:'medium', attempts:'9,870'},
    {title:`${exam.name} Speed Test`, qs:Math.min(5,qs.length), mins:5, diff:'hard', attempts:'3,200'},
  ];

  const diffClass = {easy:'diff-easy',medium:'diff-medium',hard:'diff-hard'};
  document.getElementById('testsGrid').innerHTML = tests.map((t,i) => `
    <div class="test-card">
      <div class="test-card-header">
        <h4>${t.title}</h4>
        <span class="difficulty ${diffClass[t.diff]}">${t.diff}</span>
      </div>
      <div class="test-info">
        <span>📝 <b>${t.qs}</b> Questions</span>
        <span>⏱ <b>${t.mins}</b> Mins</span>
        <span>👥 <b>${t.attempts}</b> Attempts</span>
      </div>
      <button class="start-test-btn" onclick="startTest('${examId}',${t.qs},${t.mins})">Start Test →</button>
    </div>
  `).join('');

  showPage('exams');
}

