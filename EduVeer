function renderExamGrid() {
  const grid = document.getElementById('examGrid');
  grid.innerHTML = EXAMS.map(e => `
    <div class="exam-card" onclick="openExam('${e.id}')">
      <div class="exam-icon" style="background:${e.bg}">${e.icon}</div>
      <h3>${e.name}</h3>
      <p>${e.desc}</p>
      <div class="exam-meta">
        <span class="exam-tag" style="background:${e.tagColor};color:${e.tagText};border:1px solid ${e.tagText}33">${e.tag}</span>
        <span class="exam-tag" style="background:rgba(100,116,139,0.15);color:#94A3B8;border:1px solid rgba(100,116,139,0.2)">${(QUESTION_BANK[e.id]||defaultQuestions).length} Qs</span>
      </div>
    </div>
  `).join('');
}

// ═══════════════════════════════════════════════
