//  QUIZ
// ═══════════════════════════════════════════════
function startTest(examId, numQs, mins) {
  const exam = EXAMS.find(e => e.id === examId);
  const allQs = QUESTION_BANK[examId] || defaultQuestions;
  // Shuffle and pick
  const shuffled = [...allQs].sort(()=>Math.random()-0.5);
  currentQuestions = shuffled.slice(0, Math.min(numQs, allQs.length));
  userAnswers = new Array(currentQuestions.length).fill(-1);
  currentQ = 0;
  testSubmitted = false;
  timeLeft = mins * 60;

  document.getElementById('quizTitle').textContent = exam.name;
  document.getElementById('quizSubtitle').textContent = `${currentQuestions.length} Questions · ${mins} Minutes`;

  clearInterval(timerInterval);
  timerInterval = setInterval(tickTimer, 1000);

  renderQuizNav();
  renderQuestion();
  showPage('quiz');
}

function tickTimer() {
  if(timeLeft <= 0) { clearInterval(timerInterval); submitTest(); return; }
  timeLeft--;
  const m = Math.floor(timeLeft/60).toString().padStart(2,'0');
  const s = (timeLeft%60).toString().padStart(2,'0');
  const el = document.getElementById('quizTimer');
  el.textContent = `${m}:${s}`;
  el.className = 'timer' + (timeLeft < 60 ? ' warning' : '');
}

function renderQuestion() {
  const q = currentQuestions[currentQ];
  const total = currentQuestions.length;

  document.getElementById('qNumber').textContent = `Question ${currentQ+1} of ${total}`;
  document.getElementById('qText').textContent = q.q;
  document.getElementById('progText').textContent = `Question ${currentQ+1} of ${total}`;
  const pct = Math.round((currentQ+1)/total*100);
  document.getElementById('progPct').textContent = pct+'%';
  document.getElementById('progressFill').style.width = pct+'%';

  const answered = userAnswers.filter(a=>a>=0).length;
  document.getElementById('statAnswered').textContent = answered;
  document.getElementById('statLeft').textContent = total - answered;

  const keys = ['A','B','C','D'];
  const opted = userAnswers[currentQ];
  const container = document.getElementById('optionsContainer');

  container.innerHTML = q.opts.map((opt, i) => {
    let cls = 'option';
    if(testSubmitted) {
      cls += ' disabled';
      if(i === q.ans) cls += ' correct';
      else if(i === opted && i !== q.ans) cls += ' wrong';
    } else {
      if(i === opted) cls += ' selected';
    }
    return `<div class="${cls}" onclick="${testSubmitted?'':'selectOption('+i+')'}">
      <div class="opt-key">${keys[i]}</div>
      <div class="opt-text">${opt}</div>
    </div>`;
  }).join('');

  const expEl = document.getElementById('explanation');
  if(testSubmitted) {
    expEl.innerHTML = `<strong>📖 Explanation:</strong> ${q.exp}`;
    expEl.classList.add('show');
  } else {
    expEl.classList.remove('show');
  }

  document.getElementById('btnPrev').style.display = currentQ === 0 ? 'none' : 'block';
  document.getElementById('btnNext').style.display = currentQ === total-1 ? 'none' : 'block';
  document.getElementById('btnSubmit').style.display = currentQ === total-1 ? 'block' : 'none';

  updateNavBtns();
}

function selectOption(i) {
  if(testSubmitted) return;
  userAnswers[currentQ] = i;
  renderQuestion();
  renderQuizNav();
}

function prevQuestion() { if(currentQ>0){currentQ--;renderQuestion();} }
function nextQuestion() { if(currentQ<currentQuestions.length-1){currentQ++;renderQuestion();} }

function renderQuizNav() {
  const grid = document.getElementById('qNavGrid');
  grid.innerHTML = currentQuestions.map((_,i) => {
    let cls = 'q-nav-btn';
    if(i===currentQ) cls += ' current';
    else if(testSubmitted) {
      if(userAnswers[i]===currentQuestions[i].ans) cls += ' correct-nav';
      else if(userAnswers[i]>=0) cls += ' wrong-nav';
    } else if(userAnswers[i]>=0) cls += ' answered';
    return `<button class="${cls}" onclick="jumpToQ(${i})">${i+1}</button>`;
  }).join('');
}

function jumpToQ(i) { currentQ=i; renderQuestion(); renderQuizNav(); }

function updateNavBtns() { renderQuizNav(); }

function submitTest() {
  clearInterval(timerInterval);
  testSubmitted = true;

  let correct=0, wrong=0, skip=0;
  currentQuestions.forEach((q,i)=>{
    if(userAnswers[i]===-1) skip++;
    else if(userAnswers[i]===q.ans) correct++;
    else wrong++;
  });

  const total = currentQuestions.length;
  const pct = Math.round(correct/total*100);

  const trophies = pct>=80?'🏆':pct>=60?'🎉':pct>=40?'😊':'💪';
  const titles = pct>=80?'Outstanding!':pct>=60?'Great Job!':pct>=40?'Good Effort!':'Keep Practicing!';
  const subs = pct>=80?'You are well prepared!':pct>=60?'Above average performance':pct>=40?'Room for improvement':' Review your concepts';

  document.getElementById('resultTrophy').textContent = trophies;
  document.getElementById('resultTitle').textContent = titles;
  document.getElementById('resultSub').textContent = subs;
  document.getElementById('scorePct').textContent = pct+'%';
  document.getElementById('rc-correct').textContent = correct;
  document.getElementById('rc-wrong').textContent = wrong;
  document.getElementById('rc-skip').textContent = skip;

  // Animate ring
  setTimeout(()=>{
    const circ = 427;
    document.getElementById('scoreArc').style.strokeDashoffset = circ - (circ * pct/100);
    document.getElementById('scoreArc').style.transition = 'stroke-dashoffset 1.2s ease';
  },100);

  showPage('result');
}

function reviewTest() {
  currentQ = 0;
  renderQuestion();
  renderQuizNav();
  showPage('quiz');
}

